{
	"name": "SaintapediaDrilldown",
	"version": "0.2.1",
	"author": [ "Saintapedia contributors" ],
	"url": "https://github.com/Saintapedia/SaintapediaDrilldown",
	"descriptionmsg": "saintapediadrilldown-desc",
	"license-name": "MIT",
	"type": "other",
	"requires": {
		"MediaWiki": ">= 1.39.0",
		"extensions": {
			"Cargo": ">= 3.0"
		}
	},
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\SaintapediaDrilldown\\": "includes/"
	},
	"MessagesDirs": {
		"SaintapediaDrilldown": [ "i18n" ]
	},
	"HookHandlers": {
		"main": {
			"class": "MediaWiki\\Extension\\SaintapediaDrilldown\\Hooks"
		}
	},
	"Hooks": {
		"BeforePageDisplay": "main"
	},
	"ResourceModules": {
		"ext.SaintapediaDrilldown.styles": {
			"styles": [ "modules/ext.SaintapediaDrilldown.css" ]
		},
		"ext.SaintapediaDrilldown": {
			"scripts": [ "modules/ext.SaintapediaDrilldown.js" ],
			"dependencies": [ "mediawiki.storage" ],
			"messages": [
				"saintapediadrilldown-show-filters",
				"saintapediadrilldown-hide-filters",
				"saintapediadrilldown-clear-filters",
				"saintapediadrilldown-remove-filter",
				"saintapediadrilldown-active-filters",
				"saintapediadrilldown-chip-text",
				"saintapediadrilldown-remove-filter-aria",
				"saintapediadrilldown-search-filter-label",
				"saintapediadrilldown-range-value"
			]
		}
	},
	"ResourceFileModulePaths": {
		"localBasePath": "",
		"remoteExtPath": "SaintapediaDrilldown"
	},
	"config": {
		"SaintapediaDrilldownSidebarEnabled": {
			"value": true,
			"description": "Enable the sidebar (flex) layout for Special:Drilldown. Set false to disable entirely and fall back to Cargo defaults."
		},
		"SaintapediaDrilldownSidebarWidth": {
			"value": 280,
			"description": "Width of the filter sidebar in pixels (desktop). Valid range: 120–800."
		},
		"SaintapediaDrilldownShowFilterChips": {
			"value": true,
			"description": "Show active-filter chips above the results area."
		},
		"SaintapediaDrilldownStickyFilters": {
			"value": true,
			"description": "Make the filter sidebar sticky while the user scrolls results."
		},
		"SaintapediaDrilldownMobileBreakpoint": {
			"value": 720,
			"description": "Viewport width (px) below which the layout switches to stacked / mobile mode. Valid range: 320–1600."
		}
	},
	"manifest_version": 2
}
